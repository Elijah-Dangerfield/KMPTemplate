<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme with SplashScreen API support -->
    <style name="Theme.Goodtimes" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Splash screen background color (matches Parchment300) -->
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <!-- Status bar and nav bar colors -->
        <item name="android:statusBarColor">@color/splash_background</item>
        <item name="android:navigationBarColor">@color/splash_background</item>
        <!-- Window background for after splash -->
        <item name="android:windowBackground">@color/splash_background</item>
        <!-- Dark status bar icons -->
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Splash background color matching Parchment300 from the design system -->
    <color name="splash_background">#E8DCC8</color>
</resources>
